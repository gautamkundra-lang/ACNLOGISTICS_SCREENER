# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and will NEVER be committed.

# OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# A random secret string you generate (e.g. openssl rand -hex 32)
# Used to protect the manual POST /api/refresh endpoint
REFRESH_SECRET=your-random-secret-here

# Vercel KV — these are auto-populated when you add the KV add-on in the Vercel dashboard.
# Fill these in only if running locally against a real KV store.
KV_REST_API_URL=https://your-kv-url.kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-token-here

# Email digest (optional) — daily briefing sent by the cron job.
# Get a key at https://resend.com (free tier). Until both are set, no email is sent.
RESEND_API_KEY=re_...
ALERT_EMAIL_TO=you@example.com,teammate@example.com
# Optional verified sender; defaults to Resend's onboarding address for testing.
ALERT_EMAIL_FROM=CPG Screener <onboarding@resend.dev>
